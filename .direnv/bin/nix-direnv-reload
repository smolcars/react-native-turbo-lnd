#!/usr/bin/env bash
set -e
if [[ ! -d "/Volumes/hulk/dev/projects/react-native-turbo-lnd" ]]; then
  echo "Cannot find source directory; Did you move it?"
  echo "(Looking for "/Volumes/hulk/dev/projects/react-native-turbo-lnd")"
  echo 'Cannot force reload with this script - use "direnv reload" manually and then try again'
  exit 1
fi

# rebuild the cache forcefully
_nix_direnv_force_reload=1 direnv exec "/Volumes/hulk/dev/projects/react-native-turbo-lnd" true

# Update the mtime for .envrc.
# This will cause direnv to reload again - but without re-building.
touch "/Volumes/hulk/dev/projects/react-native-turbo-lnd/.envrc"

# Also update the timestamp of whatever profile_rc we have.
# This makes sure that we know we are up to date.
touch -r "/Volumes/hulk/dev/projects/react-native-turbo-lnd/.envrc" "/Volumes/hulk/dev/projects/react-native-turbo-lnd/.direnv"/*.rc
