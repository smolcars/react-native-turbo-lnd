{
  "name": "react-native-turbo-lnd",
  "version": "0.1.2",
  "description": "C++ TurboModule for lnd! ⚡️",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/commonjs/src/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*",
    "react-native.config.js"
  ],
  "exports": {
    ".": {
      "require": {
        "types": "./lib/typescript/commonjs/src/index.d.ts",
        "defaultx": "./lib/commonjs/index.js"
      },
      "import": {
        "types": "./lib/typescript/module/src/index.d.ts",
        "default": "./lib/module/index.js"
      }
    },
    "./core": {
      "require": {
        "types": "./lib/typescript/commonjs/src/core/NativeTurboLnd.d.ts",
        "default": "./lib/commonjs/core/NativeTurboLnd"
      },
      "import": {
        "types": "./lib/typescript/module/src/core/NativeTurboLnd.d.ts",
        "default": "./lib/module/core/NativeTurboLnd"
      }
    },
    "./protos/*": {
      "require": {
        "types": "./lib/typescript/commonjs/src/proto/*.d.ts",
        "default": "./lib/commonjs/proto/*.js"
      },
      "import": {
        "types": "./lib/typescript/module/src/proto/*.d.ts",
        "default": "./lib/module/proto/*.js"
      }
    }

  },
  "scripts": {
    "example": "yarn workspace react-native-turbo-lnd-example",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "yarn generate-bindings && yarn generate-codegen-specs && bob build",
    "release": "release-it",
    "generate-codegen-specs": "node ./scripts/generate-codegen-specs.cjs",
    "generate-bindings": "yarn workspace protoc-generator generate"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hsjoberg/react-native-turbo-lnd.git"
  },
  "author": "Hampus Sjöberg <hampus.sjoberg@protonmail.com> (https://github.com/hsjoberg)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hsjoberg/react-native-turbo-lnd/issues"
  },
  "homepage": "https://github.com/hsjoberg/react-native-turbo-lnd#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@bufbuild/protobuf": "^2.0.0",
    "@commitlint/config-conventional": "^17.0.2",
    "@eslint/compat": "^1.3.2",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.35.0",
    "@evilmartians/lefthook": "^1.5.0",
    "@react-native-community/cli": "20.0.1",
    "@react-native/babel-preset": "0.81.1",
    "@react-native/eslint-config": "0.78.3",
    "@release-it/conventional-changelog": "^5.0.0",
    "@types/jest": "^29.5.5",
    "@types/react": "^19.1.0",
    "commitlint": "^17.0.2",
    "del-cli": "^5.1.0",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.0.3",
    "react": "19.1.0",
    "react-native": "0.81.4",
    "react-native-builder-bob": "0.40.13",
    "release-it": "^15.0.0",
    "turbo": "^1.10.7",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@bufbuild/protobuf": "*",
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "@bufbuild/protobuf": {
      "optional": true
    }
  },
  "workspaces": [
    "example",
    "protoc-generator"
  ],
  "packageManager": "yarn@3.6.1",
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "subject-empty": [
        0,
        "never"
      ],
      "type-empty": [
        0,
        "never"
      ]
    }
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ],
    "exclude": "protoc-generator/**"
  },
  "codegenConfig": {
    "name": "RNTurboLndSpec",
    "type": "all",
    "jsSrcsDir": "src"
  }
}
