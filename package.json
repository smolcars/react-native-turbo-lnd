{
  "name": "react-native-turbo-lnd",
  "version": "0.0.2",
  "description": "C++ TurboModule for lnd! ⚡️",
  "main": "lib/commonjs/index",
  "module": "lib/module/index",
  "types": "lib/typescript/commonjs/src/index.d.ts",
  "react-native": "src/index",
  "source": "src/index",
  "files": [
    "src",
    "lib",
    "android",
    "ios",
    "cpp",
    "*.podspec",
    "!ios/build",
    "!android/build",
    "!android/gradle",
    "!android/gradlew",
    "!android/gradlew.bat",
    "!android/local.properties",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*",
    "react-native.config.js"
  ],
  "exports": {
    ".": {
      "require": {
        "types": "./lib/typescript/commonjs/src/index.d.ts",
        "defaultx": "./lib/commonjs/index.js"
      },
      "import": {
        "types": "./lib/typescript/module/src/index.d.ts",
        "default": "./lib/module/index.js"
      }
    },
    "./package.json": {
      "require": "./package.json",
      "import": "./package.json"
    },
    "./core": {
      "require": {
        "types": "./lib/typescript/commonjs/src/core/NativeTurboLnd.d.ts",
        "default": "./lib/commonjs/core/NativeTurboLnd"
      },
      "import": {
        "types": "./lib/typescript/module/src/core/NativeTurboLnd.d.ts",
        "default": "./lib/module/core/NativeTurboLnd"
      }
    },
    "./mock": {
      "require": {
        "types": "./lib/typescript/commonjs/src/mock.d.ts",
        "default": "./lib/commonjs/mock.js"
      },
      "import": {
        "types": "./lib/typescript/module/src/mock.d.ts",
        "default": "./lib/module/mock.js"
      }
    },
    "./protos/*": {
      "require": {
        "types": "./lib/typescript/commonjs/src/proto/*.d.ts",
        "default": "./lib/commonjs/proto/*.js"
      },
      "import": {
        "types": "./lib/typescript/module/src/proto/*.d.ts",
        "default": "./lib/module/proto/*.js"
      }
    }
  },
  "scripts": {
    "example": "bun run --cwd example",
    "build": "bun run generate-bindings && bun run generate-codegen-specs && bun run bob",
    "bob": "bob build",
    "test": "bun test tests/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
    "prepare": "lefthook install && node ./scripts/fix-lefthook-hooks.cjs",
    "prepack": "bun run build",
    "release": "release-it",
    "generate-codegen-specs": "node ./scripts/generate-codegen-specs.cjs",
    "generate-bindings": "bun run --cwd protoc-generator generate"
  },
  "keywords": [
    "react-native",
    "ios",
    "android"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hsjoberg/react-native-turbo-lnd.git"
  },
  "author": "Hampus Sjöberg <hampus.sjoberg@protonmail.com> (https://github.com/hsjoberg)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/hsjoberg/react-native-turbo-lnd/issues"
  },
  "homepage": "https://github.com/hsjoberg/react-native-turbo-lnd#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "^7.25.1",
    "@bufbuild/protobuf": "^2.0.0",
    "@commitlint/config-conventional": "^20.4.2",
    "@eslint/compat": "^2.0.2",
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^10.0.1",
    "@evilmartians/lefthook": "^2.1.2",
    "@react-native-community/cli": "20.1.2",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/eslint-plugin": "0.84.1",
    "@release-it/conventional-changelog": "^10.0.5",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "commitlint": "^20.4.2",
    "del-cli": "^7.0.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-ft-flow": "^3.0.11",
    "eslint-plugin-jest": "^29.15.0",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-react": "^7.30.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-native": "^5.0.0",
    "prettier": "^3.0.3",
    "react": "19.2.4",
    "react-native": "0.84.1",
    "react-native-builder-bob": "0.40.18",
    "release-it": "^19.2.4",
    "turbo": "^2.8.12",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "@bufbuild/protobuf": "*",
    "react": "*",
    "react-native": "*"
  },
  "peerDependenciesMeta": {
    "@bufbuild/protobuf": {
      "optional": true
    }
  },
  "workspaces": [
    "example",
    "protoc-generator"
  ],
  "packageManager": "bun@1.3.8",
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/example/node_modules",
      "<rootDir>/lib/"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "subject-empty": [
        0,
        "never"
      ],
      "type-empty": [
        0,
        "never"
      ]
    }
  },
  "release-it": {
    "git": {
      "commitMessage": "chore: release ${version}",
      "tagName": "v${version}"
    },
    "npm": {
      "publish": true
    },
    "github": {
      "release": true
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  },
  "eslintIgnore": [
    "node_modules/",
    "lib/"
  ],
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ],
    "exclude": "protoc-generator/**"
  },
  "codegenConfig": {
    "name": "RNTurboLndSpec",
    "type": "all",
    "jsSrcsDir": "src"
  }
}
